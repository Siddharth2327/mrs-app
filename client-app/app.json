{
  "expo": {
    "name": "Riswana Transport",
    "slug": "client-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/EntLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "mbs",
    "splash": {
      "image": "./assets/EntLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/EntLogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.clientapp",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/EntLogo.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2f18dd8-bf89-4a20-aa05-fbe03fbf1489"
      }
    }
  }
}
